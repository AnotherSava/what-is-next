# Reference list of all config variables — values live in Doppler (whats-next/dev).
# Set them with: doppler secrets set KEY=value -p whats-next -c dev
# For deploy without Doppler, copy this to .env and fill in real values (Next.js auto-loads .env).

# SQLite database file. Dev: relative to web/. Prod (Docker): file:/data/whats-next.db
DATABASE_URL="file:./prisma/dev.db"

# Owner login password (single-owner console)
ADMIN_PASSWORD="change-me"

# Secret for signing the owner session cookie — generate with:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-64-hex-chars"

# TMDB v4 Read Access Token (Bearer). Register free at https://www.themoviedb.org/settings/api
TMDB_API_TOKEN="change-me"

# Public access mode: "readonly" (default — anyone can browse read-only) | "off" (owner-only; viewers redirected to /login)
PUBLIC_ACCESS="readonly"

# Nightly metadata-refresh schedule (cron, UTC). Optional; default 0 11 * * * (~4am Pacific).
# REFRESH_CRON="0 11 * * *"

# Timezone for date rendering and cron. Optional; default host TZ.
TZ="America/Vancouver"

# --- Plex integration (optional; the whole feature is hidden when PLEX_TOKEN is unset) ---
# Base URL of your Plex Media Server (e.g. http://localhost:32400, or http://<server-ip>:32400 on a VPS).
# PLEX_URL="http://localhost:32400"
# A Plex auth token (X-Plex-Token). Find it via https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
# PLEX_TOKEN="your-plex-token"
# Optional: restrict the sync to specific Plex library titles (comma-separated). Unset = all TV+movie libraries.
# PLEX_LIBRARIES="TV Shows,Movies"

# --- TVDB fallback (optional; hydrates titles TMDB can't resolve, e.g. fan/web content) ---
# TVDB v4 API key. Register at https://thetvdb.com/dashboard → API keys (free under $50k revenue, with attribution).
# TVDB_API_KEY="your-tvdb-api-key"
# Subscriber PIN — ONLY for a "user-supported" key (paired with a TVDB subscription). Omit for a licensed key.
# TVDB_PIN="your-subscriber-pin"
